    <string name="about_dialog_title">About</string>
    <string name="about_dialog_body">YourGuide helps travelers explore guides, check weather, and compare USD exchange rates in one place.</string>
    <string name="privacy_dialog_title">Privacy Policy</string>
    <string name="privacy_intro">This policy explains how YourGuide handles information inside the app.</string>
    <string name="privacy_section_info_title">Information we use</string>
    <string name="privacy_section_info_body">We may use your profile details from sign-in, saved items, language preference, search activity inside the app, and content you choose to view.</string>
    <string name="privacy_section_use_title">How we use it</string>
    <string name="privacy_section_use_body">We use this information to sign you in, personalize the interface, show your saved content, and provide features such as weather and exchange-rate screens.</string>
    <string name="privacy_section_third_party_title">Third-party services</string>
    <string name="privacy_section_third_party_body">YourGuide relies on external services such as Firebase for authentication and data storage, weather and exchange-rate APIs, and advertising services if enabled. These providers may process data according to their own policies.</string>
    <string name="privacy_section_retention_title">Data retention</string>
    <string name="privacy_section_retention_body">We keep app data only as long as needed to provide features tied to your account. You can sign out at any time, and local data can be removed by deleting the app.</string>
    <string name="privacy_section_choices_title">Your choices</string>
    <string name="privacy_section_choices_body">You can change language preference, clear the app from your device, and stop using the app at any time. For questions, contact the developer through the store listing or app support channel.</string>
    <string name="privacy_section_sharing_title">Data sharing</string>
    <string name="privacy_section_sharing_body">We do not sell personal data.</string>
